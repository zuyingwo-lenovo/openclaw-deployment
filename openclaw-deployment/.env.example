# OpenClaw Environment Variables Example
# Do NOT put real keys in this file. Copy to ~/.openclaw/.env and edit there.

# Model Provider Keys
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIza..."

# Optional Web Search Providers (if using web_search tool)
BRAVE_API_KEY="..."
FIRECRAWL_API_KEY="..."

# Optional Browser Settings
# Set this if you want to use Browserless instead of local WSL Chromium
# BROWSERLESS_API_KEY="..."

# Optional MCP Endpoints
# MCP_SERVER_URL="http://localhost:8080"
